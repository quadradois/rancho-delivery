# Configuração do Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sabor_express"

# Configuração do Servidor
NODE_ENV="development"
PORT=3001
HOST=127.0.0.1

# Frontend URL (para CORS e redirect após pagamento)
FRONTEND_URL="http://localhost:3000"

# InfinitePay (Gateway de Pagamento)
# Sua InfiniteTag sem o $ do início
INFINITEPAY_HANDLE="orancho-comida"
# Secret para validar webhooks (configure no painel InfinitePay)
INFINITEPAY_WEBHOOK_SECRET="seu_webhook_secret_aqui"
# URL pública chamada pela InfinitePay ao confirmar pagamento
INFINITEPAY_WEBHOOK_URL="https://rancho.delivery/webhook/infinitepay"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua_api_key_aqui"
EVOLUTION_INSTANCE_NAME="rancho-comida"

# WhatsApp do Dono (para notificações)
# Formato: código país + DDD + número (ex: 5562999999999)
WHATSAPP_DONO="5562999999999"

# Logs
LOG_LEVEL="info"

# JWT (para autenticação do painel admin - Fase futura)
JWT_SECRET="seu_secret_super_seguro_aqui"
JWT_EXPIRES_IN="7d"

# Upload de Imagens (Fase futura)
UPLOAD_MAX_SIZE="5242880"
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/webp,video/mp4"
