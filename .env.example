# Configuração do Banco de Dados
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sabor_express"

# Configuração do Servidor
NODE_ENV="development"
PORT=3001

# Frontend URL (para CORS)
FRONTEND_URL="http://localhost:3000"

# Asaas (Gateway de Pagamento)
ASAAS_API_KEY="sua_api_key_aqui"
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_WEBHOOK_TOKEN="seu_webhook_token_aqui"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua_api_key_aqui"
EVOLUTION_INSTANCE_NAME="sabor-express"

# WhatsApp do Dono (para notificações)
# Formato: código país + DDD + número (ex: 5562999999999)
WHATSAPP_DONO="5562999999999"

# Logs
LOG_LEVEL="info"

# JWT (para autenticação do painel admin - Fase futura)
JWT_SECRET="seu_secret_super_seguro_aqui"
JWT_EXPIRES_IN="7d"

# Upload de Imagens (Fase futura)
UPLOAD_MAX_SIZE="5242880"
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/webp,video/mp4"

# Assertiva (Mineração de Contatos - Fase 2)
ASSERTIVA_API_KEY="sua_api_key_aqui"
ASSERTIVA_API_URL="https://api.assertivasolucoes.com.br"
