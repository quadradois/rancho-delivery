// Schema do Prisma para Rancho
// Gerado seguindo o planejamento em docs/planejamento/PLANEJAMENTO_SABOR_EXPRESS.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Entidade central: Cliente
// Identificador único: telefone (WhatsApp)
model Cliente {
  telefone   String   @id @db.VarChar(20)
  nome       String   @db.VarChar(255)
  endereco   String   @db.Text
  bairro     String   @db.VarChar(100)
  cep        String?  @db.VarChar(8)
  numero     String?  @db.VarChar(20)
  quadra     String?  @db.VarChar(20)
  lote       String?  @db.VarChar(20)
  complemento String? @db.VarChar(100)
  lat        Float?
  lng        Float?
  nrinscr    String?  @db.VarChar(14)
  ativo      Boolean  @default(true)
  origem     Origem   @default(SITE)
  criadoEm   DateTime @default(now()) @map("criado_em")
  
  // Relações
  pedidos    Pedido[]
  mensagens  MensagemCliente[]
  listaNegra ListaNegraCliente?
  indicacoes Indicacao[] @relation("Indicador")
  indicadoPor Indicacao? @relation("Indicado")
  leadsMarketing LeadMarketing[]
  
  @@map("clientes")
  @@index([bairro])
  @@index([origem])
}

// Enum para origem do cliente
enum Origem {
  SITE
  WHATSAPP
  MINERACAO
  INDICACAO
  CAMPANHA
}

enum LeadStatus {
  ATIVO
  CONVERTIDO
  INVALIDO
  OPT_OUT
}

enum CampanhaStatus {
  RASCUNHO
  AGENDADA
  ENVIANDO
  CONCLUIDA
  FALHA
  DESATIVADA
}

// Produtos do cardápio
model Produto {
  id           String   @id @default(cuid())
  nome         String   @db.VarChar(255)
  preco        Decimal  @db.Decimal(10, 2)
  midia        String   @db.Text // URL da foto ou vídeo
  descricao    String   @db.Text
  categoria    String   @db.VarChar(100)
  disponivel   Boolean  @default(true)
  ordem        Int      @default(0) // Ordem no feed
  tempoPreparo Int      @default(15) @map("tempo_preparo") // Minutos
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  
  // Relações
  itensPedido  ItemPedido[]
  fichaTecnica FichaTecnica?
  
  @@map("produtos")
  @@index([categoria])
  @@index([disponivel])
  @@index([ordem])
}

// Bairros atendidos e taxas de entrega
model Bairro {
  id              String   @id @default(cuid())
  nome            String   @unique @db.VarChar(100)
  cep             String?  @db.VarChar(9)
  taxa            Decimal  @db.Decimal(10, 2)
  tempoEntrega    Int      @default(30) @map("tempo_entrega") // Minutos
  ativo           Boolean  @default(true)
  linkIfood       String?  @map("link_ifood") @db.Text
  link99food      String?  @map("link_99food") @db.Text
  linkOutro       String?  @map("link_outro") @db.Text
  nomeOutro       String?  @map("nome_outro") @db.VarChar(100)

  @@map("bairros")
  @@index([ativo])
  @@index([cep])
}

// Pedidos
model Pedido {
  id              String        @id @default(cuid())
  clienteTelefone String        @map("cliente_telefone") @db.VarChar(20)
  enderecoEntrega String?       @map("endereco_entrega") @db.Text
  bairroEntrega   String?       @map("bairro_entrega") @db.VarChar(100)
  formaPagamento  FormaPagamentoPedido @default(PIX) @map("forma_pagamento")
  trocoPara       Decimal?      @map("troco_para") @db.Decimal(10, 2)
  tipoAtendimento TipoAtendimentoPedido @default(ENTREGA) @map("tipo_atendimento")
  subtotal        Decimal       @db.Decimal(10, 2)
  taxaEntrega     Decimal       @map("taxa_entrega") @db.Decimal(10, 2)
  total           Decimal       @db.Decimal(10, 2)
  status          StatusPedido  @default(PENDENTE)
  statusPagamento StatusPagamento @default(PENDENTE) @map("status_pagamento")
  statusMudouEm   DateTime      @default(now()) @map("status_mudou_em")
  pagamentoId     String?       @map("pagamento_id") @db.VarChar(255) // ID do Asaas
  motoboyId       String?       @map("motoboy_id")
  observacaoEntrega String?     @map("observacao_entrega") @db.Text
  canceladoMotivo String?       @map("cancelado_motivo") @db.Text
  estornoNecessario Boolean     @default(false) @map("estorno_necessario")
  estornoRealizadoEm DateTime?  @map("estorno_realizado_em")
  pagamentoExpiraEm DateTime?   @map("pagamento_expira_em")
  abandonadoEm    DateTime?     @map("abandonado_em")
  recuperadoEm    DateTime?     @map("recuperado_em")
  tentativasRecuperacao Int     @default(0) @map("tentativas_recuperacao")
  npsEnviadoEm    DateTime?     @map("nps_enviado_em")
  npsNota         Int?          @map("nps_nota")
  npsFeedback     String?       @map("nps_feedback") @db.Text
  observacao      String?       @db.Text
  tokenAcesso     String?       @unique @map("token_acesso") @db.VarChar(64)
  criadoEm        DateTime      @default(now()) @map("criado_em")
  atualizadoEm    DateTime      @updatedAt @map("atualizado_em")

  // Relações
  cliente Cliente      @relation(fields: [clienteTelefone], references: [telefone])
  motoboy Motoboy?     @relation(fields: [motoboyId], references: [id], onDelete: SetNull)
  itens   ItemPedido[]
  mensagens MensagemCliente[]
  timeline PedidoTimeline[]

  @@map("pedidos")
  @@index([clienteTelefone])
  @@index([status])
  @@index([motoboyId])
  @@index([criadoEm])
  @@index([statusPagamento])
  @@index([pagamentoExpiraEm])
  @@index([estornoNecessario])
  @@index([status, criadoEm])
}

enum StatusPagamento {
  PENDENTE
  CONFIRMADO
  A_RECEBER
  EXPIRADO
}

enum FormaPagamentoPedido {
  PIX
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
}

enum TipoAtendimentoPedido {
  ENTREGA
  RETIRADA
  CONSUMO_LOCAL
}

// Enum para status do pedido
enum StatusPedido {
  PENDENTE
  AGUARDANDO_PAGAMENTO
  CONFIRMADO
  PREPARANDO
  PRONTO
  SAIU_ENTREGA
  ENTREGUE
  EXPIRADO
  ABANDONADO
  CANCELADO
}

enum OrigemMensagem {
  HUMANO
  SISTEMA
  IA
}

model PedidoTimeline {
  id        String   @id @default(cuid())
  pedidoId  String   @map("pedido_id")
  ator      String   @db.VarChar(40)
  acao      String   @db.Text
  criadoEm  DateTime @default(now()) @map("criado_em")

  pedido    Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("pedido_timeline")
  @@index([pedidoId])
  @@index([criadoEm])
}

// Itens do pedido
model ItemPedido {
  id         String  @id @default(cuid())
  pedidoId   String  @map("pedido_id")
  produtoId  String  @map("produto_id")
  quantidade Int
  precoUnit  Decimal @map("preco_unit") @db.Decimal(10, 2)
  subtotal   Decimal @db.Decimal(10, 2)
  observacao String? @db.Text
  
  // Relações
  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id])
  
  @@map("itens_pedido")
  @@index([pedidoId])
  @@index([produtoId])
}

// Ficha técnica (Fase 3 - F04)
model FichaTecnica {
  id              String               @id @default(cuid())
  produtoId       String               @unique @map("produto_id")
  custoProducao   Decimal              @map("custo_producao") @db.Decimal(10, 2)
  margemAlvo      Decimal              @map("margem_alvo") @db.Decimal(5, 2) // Percentual
  criadoEm        DateTime             @default(now()) @map("criado_em")
  atualizadoEm    DateTime             @updatedAt @map("atualizado_em")
  
  // Relações
  produto      Produto               @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  ingredientes IngredienteFicha[]
  
  @@map("fichas_tecnicas")
}

// Ingredientes da ficha técnica
model IngredienteFicha {
  id              String       @id @default(cuid())
  fichaTecnicaId  String       @map("ficha_tecnica_id")
  ingrediente     String       @db.VarChar(255)
  quantidadeUsada Decimal      @map("quantidade_usada") @db.Decimal(10, 3)
  unidade         String       @db.VarChar(20)
  custoUnitario   Decimal      @map("custo_unitario") @db.Decimal(10, 2)
  
  // Relações
  fichaTecnica FichaTecnica @relation(fields: [fichaTecnicaId], references: [id], onDelete: Cascade)
  
  @@map("ingredientes_ficha")
  @@index([fichaTecnicaId])
}

// Programa de indicação (Fase 4 - F06)
model Indicacao {
  id              String   @id @default(cuid())
  indicadorTelefone String @map("indicador_telefone") @db.VarChar(20)
  indicadoTelefone  String @unique @map("indicado_telefone") @db.VarChar(20)
  codigoIndicacao   String @unique @map("codigo_indicacao") @db.VarChar(50)
  bonificado        Boolean @default(false)
  criadoEm          DateTime @default(now()) @map("criado_em")
  
  // Relações
  indicador Cliente @relation("Indicador", fields: [indicadorTelefone], references: [telefone])
  indicado  Cliente @relation("Indicado", fields: [indicadoTelefone], references: [telefone])
  
  @@map("indicacoes")
  @@index([indicadorTelefone])
  @@index([codigoIndicacao])
}

// Roleta de promoções (Fase 4 - F05)
model RoletaGiro {
  id              String   @id @default(cuid())
  clienteTelefone String   @map("cliente_telefone") @db.VarChar(20)
  premio          String   @db.VarChar(255)
  utilizado       Boolean  @default(false)
  dataExpiracao   DateTime @map("data_expiracao")
  criadoEm        DateTime @default(now()) @map("criado_em")
  
  @@map("roleta_giros")
  @@index([clienteTelefone])
  @@index([utilizado])
}

// Contatos minerados (Fase 2 - F02)
model ContatoMinerado {
  id          String   @id @default(cuid())
  telefone    String   @unique @db.VarChar(20)
  nome        String?  @db.VarChar(255)
  endereco    String?  @db.Text
  bairro      String?  @db.VarChar(100)
  fonte       String   @db.VarChar(100) // Ex: "Assertiva", "Google Maps"
  abordado    Boolean  @default(false)
  convertido  Boolean  @default(false)
  criadoEm    DateTime @default(now()) @map("criado_em")
  
  @@map("contatos_minerados")
  @@index([abordado])
  @@index([convertido])
}

model MensagemCliente {
  id              String         @id @default(cuid())
  clienteTelefone String         @map("cliente_telefone") @db.VarChar(20)
  pedidoId        String?        @map("pedido_id")
  origem          OrigemMensagem
  texto           String         @db.Text
  lida            Boolean        @default(false)
  criadoEm        DateTime       @default(now()) @map("criado_em")

  cliente         Cliente        @relation(fields: [clienteTelefone], references: [telefone], onDelete: Cascade)
  pedido          Pedido?        @relation(fields: [pedidoId], references: [id], onDelete: SetNull)

  @@map("mensagens_cliente")
  @@index([clienteTelefone])
  @@index([origem])
  @@index([lida])
  @@index([criadoEm])
}

model ListaNegraCliente {
  id              String   @id @default(cuid())
  clienteTelefone String   @unique @map("cliente_telefone") @db.VarChar(20)
  motivo          String   @db.Text
  nivel           Int      @default(1) // 1=Atenção, 2=Revisão, 3=Bloqueio
  totalOcorrencias Int     @default(1) @map("total_ocorrencias")
  registradoPor   String?  @map("registrado_por") @db.VarChar(100)
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  cliente         Cliente  @relation(fields: [clienteTelefone], references: [telefone], onDelete: Cascade)
  ocorrencias     OcorrenciaListaNegra[]

  @@map("lista_negra_clientes")
  @@index([criadoEm])
  @@index([nivel])
}

model OcorrenciaListaNegra {
  id              String   @id @default(cuid())
  clienteTelefone String   @map("cliente_telefone") @db.VarChar(20)
  motivo          String   @db.Text
  registradoPor   String?  @map("registrado_por") @db.VarChar(100)
  criadoEm        DateTime @default(now()) @map("criado_em")

  listaNegra      ListaNegraCliente @relation(fields: [clienteTelefone], references: [clienteTelefone], onDelete: Cascade)

  @@map("ocorrencias_lista_negra")
  @@index([clienteTelefone])
  @@index([criadoEm])
}

enum StatusMotoboy {
  DISPONIVEL
  EM_ENTREGA
  INATIVO
}

enum EmpresaEntrega {
  PROPRIO
  IFOOD
  MUVE
  FOOD99
}

model Motoboy {
  id                  String         @id @default(cuid())
  nome                String         @db.VarChar(255)
  telefone            String         @unique @db.VarChar(20)
  empresa             EmpresaEntrega @default(PROPRIO)
  status              StatusMotoboy  @default(DISPONIVEL)
  tipoRemuneracao     String         @default("FIXO_POR_ENTREGA") @map("tipo_remuneracao")
  percentualEntregas  Float?         @map("percentual_entregas")
  valorFixoPorEntrega Float?         @map("valor_fixo_por_entrega")
  criadoEm            DateTime       @default(now()) @map("criado_em")
  atualizadoEm        DateTime       @updatedAt @map("atualizado_em")

  pedidos     Pedido[]

  @@map("motoboys")
  @@index([status])
}

enum StatusLoja {
  ABERTO
  FECHADO
  PAUSADO
}

model LojaConfiguracao {
  id               String     @id @default("loja_principal")
  status           StatusLoja @default(ABERTO)
  mensagemPausado  String?    @map("mensagem_pausado") @db.Text
  entregadoresDisponiveisDia Int @default(0) @map("entregadores_disponiveis_dia")
  mercadopagoAtivo         Boolean @default(false) @map("mercadopago_ativo")
  mercadopagoPublicKey     String? @map("mercadopago_public_key") @db.VarChar(255)
  mercadopagoAccessToken   String? @map("mercadopago_access_token") @db.Text
  mercadopagoWebhookSecret String? @map("mercadopago_webhook_secret") @db.VarChar(255)
  mercadopagoWebhookUrl    String? @map("mercadopago_webhook_url") @db.VarChar(500)
  enderecoLoja     String? @map("endereco_loja") @db.VarChar(500)
  latLoja          Float?  @map("lat_loja")
  lngLoja          Float?  @map("lng_loja")
  faixasEntrega    Json?   @map("faixas_entrega")
  // Base de conhecimento da IA
  iaDescricaoNegocio   String? @map("ia_descricao_negocio") @db.Text
  iaVozMarca           Json?   @map("ia_voz_marca")
  iaDiferenciais       Json?   @map("ia_diferenciais")
  iaHorarios           Json?   @map("ia_horarios")
  iaPoliticaFrete      String? @map("ia_politica_frete") @db.Text
  iaPoliticaPrimeiroPedido String? @map("ia_politica_primeiro_pedido") @db.Text
  iaNomeAtendente      String? @map("ia_nome_atendente") @db.VarChar(100)
  atualizadoEm     DateTime   @updatedAt @map("atualizado_em")

  @@map("loja_configuracao")
}

model ConfiguracaoAlerta {
  id         String   @id @default(cuid())
  tipo       String   @unique @db.VarChar(60)
  ativo      Boolean  @default(true)
  threshold  Int      @default(0) // segundos ou minutos dependendo do tipo
  acao       String   @db.VarChar(100) @default("som+badge")
  criadoEm   DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("configuracoes_alerta")
}

model RelatorioDia {
  id                   String   @id @default(cuid())
  data                 DateTime @unique @db.Date
  pedidosRecebidos     Int      @map("pedidos_recebidos")
  pedidosEntregues     Int      @map("pedidos_entregues")
  pedidosCancelados    Int      @map("pedidos_cancelados")
  motivosCancelamento  Json?    @map("motivos_cancelamento")
  tempoMedioPreparo    Int?     @map("tempo_medio_preparo")
  tempoMedioEntrega    Int?     @map("tempo_medio_entrega")
  receitaBruta         Decimal  @map("receita_bruta") @db.Decimal(10, 2)
  ticketMedio          Decimal  @map("ticket_medio") @db.Decimal(10, 2)
  receitaOntem         Decimal? @map("receita_ontem") @db.Decimal(10, 2)
  mensagensRespondidas Int      @map("mensagens_respondidas")
  mensagensTotal       Int      @map("mensagens_total")
  piorHorario          String?  @map("pior_horario") @db.VarChar(20)
  produtoMaisVendido   String?  @map("produto_mais_vendido") @db.VarChar(255)
  entregasRealizadas   Int      @default(0) @map("entregas_realizadas")
  taxaEntregaTotal     Decimal  @default(0) @map("taxa_entrega_total") @db.Decimal(10, 2)
  entregasPorResponsavel Json?  @map("entregas_por_responsavel")
  entregasPorHora      Json?    @map("entregas_por_hora")
  criadoEm             DateTime @default(now()) @map("criado_em")

  @@map("relatorios_dia")
  @@index([data])
}

model LeadMarketing {
  id                 String     @id @default(cuid())
  telefone           String     @unique @db.VarChar(20)
  cpfCnpj            String?    @unique @map("cpf_cnpj") @db.VarChar(14)
  telefones          Json?
  nome               String?    @db.VarChar(255)
  endereco           String?    @db.Text
  bairro             String?    @db.VarChar(100)
  origemMineracao    String     @map("origem_mineracao") @db.VarChar(255)
  status             LeadStatus @default(ATIVO)
  notas              String?    @db.Text
  convertidoEm       DateTime?  @map("convertido_em")
  clienteTelefone    String?    @map("cliente_telefone") @db.VarChar(20)
  criadoEm           DateTime   @default(now()) @map("criado_em")
  atualizadoEm       DateTime   @updatedAt @map("atualizado_em")
  ultimaInteracaoEm  DateTime?  @map("ultima_interacao_em")
  humanRequired      Boolean    @default(false) @map("human_required")

  cliente            Cliente?   @relation(fields: [clienteTelefone], references: [telefone], onDelete: SetNull)
  campanhas          CampanhaDestinatario[]
  mensagens          MensagemLead[]

  @@map("leads_marketing")
  @@index([status])
  @@index([origemMineracao])
  @@index([bairro])
  @@index([ultimaInteracaoEm])
}

model MensagemLead {
  id          String         @id @default(cuid())
  leadId      String         @map("lead_id")
  origem      OrigemMensagem
  texto       String         @db.Text
  lida        Boolean        @default(false)
  criadoEm    DateTime       @default(now()) @map("criado_em")

  lead        LeadMarketing  @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("mensagens_lead")
  @@index([leadId, criadoEm])
}

model ExecucaoMineracao {
  id                 String    @id @default(cuid())
  runId              String    @unique @map("run_id") @db.VarChar(64)
  modo               String    @db.VarChar(40)
  termo              String    @db.VarChar(255)
  filtros            Json?
  status             String    @db.VarChar(40) // SUCESSO | FALHA
  erro               String?   @db.Text
  totalImoveis       Int       @default(0) @map("total_imoveis")
  totalIptus         Int       @default(0) @map("total_iptus")
  contatosGerados    Int       @default(0) @map("contatos_gerados")
  contatosUteis      Int       @default(0) @map("contatos_uteis")
  duracoes           Json?
  criadoPor          String?   @map("criado_por") @db.VarChar(100)
  criadoEm           DateTime  @default(now()) @map("criado_em")

  @@map("execucoes_mineracao")
  @@index([criadoEm])
}

model ImovelPrefeitura {
  id           String   @id @default(cuid())
  objectId     Int?     @unique @map("object_id")
  nrinscr      String   @unique @db.VarChar(14)
  instatus     Int?
  inposfisc    Int?
  cdlogradou   Int?     @map("cdlogradou")
  tplogradou   String?  @db.VarChar(10)
  nmlogradou   String?  @db.VarChar(100)
  nrimovel     String?  @db.VarChar(20)
  incompl      String?  @db.VarChar(50)
  nrquadra     String?  @db.VarChar(20)
  nrlote       String?  @db.VarChar(20)
  cdbairro     Int?
  nmbairro     String?  @db.VarChar(100)
  cdedificio   Int?
  nmedificio   String?  @db.VarChar(100)
  raw          Json?
  latitude     Float?
  longitude    Float?
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  @@map("imoveis_prefeitura")
  @@index([nmbairro])
  @@index([nmlogradou])
  @@index([nmedificio])
  @@index([cdbairro])
}

model ImovelGeo360 {
  id                    String   @id @default(cuid())
  cidade                String   @db.VarChar(50)
  inscricaoCartografica String   @db.VarChar(20)  @map("inscricao_cartografica")
  idLote                Int?     @map("id_lote")
  numeroCadastro        Int?     @map("numero_cadastro")
  cpfCnpj               String?  @db.VarChar(20)  @map("cpf_cnpj")
  nomePessoa            String?  @db.VarChar(255) @map("nome_pessoa")
  tipoPessoa            Int?     @map("tipo_pessoa")
  endereco              String?  @db.Text
  bairro                String?  @db.VarChar(100)
  cep                   String?  @db.VarChar(8)
  latitude              Float?
  longitude             Float?
  sincronizadoEm        DateTime @default(now()) @map("sincronizado_em")
  atualizadoEm          DateTime @updatedAt       @map("atualizado_em")

  @@unique([cidade, inscricaoCartografica])
  @@map("imoveis_geo360")
  @@index([cidade])
  @@index([cpfCnpj])
  @@index([bairro])
  @@index([cep])
}

model AssertivaConsultaCache {
  id              String   @id @default(cuid())
  cpfCnpj         String   @unique @map("cpf_cnpj") @db.VarChar(14)
  tipoDocumento   String   @map("tipo_documento") @db.VarChar(4)
  telefones       Json?
  emails          Json?
  raw             Json?
  fonte           String   @default("ASSERTIVA") @db.VarChar(40)
  consultadoEm    DateTime @default(now()) @map("consultado_em")
  expiraEm        DateTime @map("expira_em")
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  @@map("assertiva_consultas_cache")
  @@index([expiraEm])
  @@index([consultadoEm])
}

model ScraperErro {
  id         String   @id @default(cuid())
  nrinscr    String   @db.VarChar(14)
  runId      String   @map("run_id") @db.VarChar(64)
  tentativas Int      @default(1)
  ultimoErro String   @db.Text
  httpStatus Int?     @map("http_status")
  criadoEm   DateTime @default(now()) @map("criado_em")

  @@map("scraper_erros")
  @@index([runId])
  @@index([criadoEm])
}

model CampanhaMarketing {
  id                 String         @id @default(cuid())
  nome               String         @db.VarChar(255)
  mensagem           String         @db.Text
  filtro             Json?
  status             CampanhaStatus @default(RASCUNHO)
  criadoPor          String?        @map("criado_por") @db.VarChar(100)
  criadoEm           DateTime       @default(now()) @map("criado_em")
  atualizadoEm       DateTime       @updatedAt @map("atualizado_em")
  enviadaEm          DateTime?      @map("enviada_em")
  agendadaPara       DateTime?      @map("agendada_para")
  erro               String?        @db.Text

  destinatarios      CampanhaDestinatario[]

  @@map("campanhas_marketing")
  @@index([status])
  @@index([criadoEm])
  @@index([agendadaPara])
}

model CampanhaDestinatario {
  id                 String   @id @default(cuid())
  campanhaId         String   @map("campanha_id")
  leadId             String   @map("lead_id")
  statusEnvio        String   @map("status_envio") @db.VarChar(40) // PENDENTE | ENVIADO | FALHA | IGNORADO_CONVERTIDO
  motivoFalha        String?  @map("motivo_falha") @db.Text
  tentativas         Int      @default(0)
  enviadoEm          DateTime? @map("enviado_em")
  criadoEm           DateTime @default(now()) @map("criado_em")

  campanha           CampanhaMarketing @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  lead               LeadMarketing     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("campanhas_destinatarios")
  @@unique([campanhaId, leadId])
  @@index([statusEnvio])
}

model BlacklistWhatsApp {
  telefone  String   @id @db.VarChar(20)
  motivo    String?  @db.Text
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("blacklist_whatsapp")
}

model SessaoPedidoWhatsApp {
  id                String    @id @default(cuid())
  clienteTelefone   String    @db.VarChar(20)
  status            String    @default("ATIVA") // ATIVA | FINALIZADA | EXPIRADA
  itens             Json      @default("[]")    // [{produtoId, nome, preco, quantidade, observacao?}]
  subtotal          Decimal   @default(0) @db.Decimal(10, 2)
  taxaEntrega       Decimal?  @db.Decimal(10, 2)
  endereco          String?   @db.Text
  bairro            String?   @db.VarChar(100)
  cep               String?   @db.VarChar(8)
  lat               Float?
  lng               Float?
  criadoEm         DateTime  @default(now()) @map("criado_em")
  ultimaInteracaoEm DateTime  @updatedAt @map("ultima_interacao_em")
  expiradaEm        DateTime? @map("expirada_em")
  pedidoId          String?   @unique @map("pedido_id")

  @@index([clienteTelefone, status])
  @@index([ultimaInteracaoEm])
  @@map("sessao_pedido_whatsapp")
}
