NODE_ENV=development
PORT=3001
HOST=127.0.0.1

DATABASE_URL="postgresql://user:password@localhost:5432/rancho_delivery"

FRONTEND_URL="http://localhost:3000"

# InfinitePay
INFINITEPAY_HANDLE="seu-handle"
INFINITEPAY_WEBHOOK_SECRET="seu-webhook-secret-base64"
INFINITEPAY_WEBHOOK_URL="https://seu-dominio.com/webhook/infinitepay"

# Evolution API (WhatsApp)
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-api-key"
EVOLUTION_INSTANCE_NAME="rancho-delivery"
# Número do dono para notificações (ex: 5562999990000)
WHATSAPP_DONO=""

LOG_LEVEL="info"

# JWT
JWT_SECRET="gere-com: openssl rand -base64 32"
JWT_EXPIRES_IN="12h"

# Upload
UPLOAD_MAX_SIZE="5242880"
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/webp,video/mp4"

# Admin
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="troque-esta-senha"
# Papel do admin: admin | operador | viewer
# - admin: acesso total
# - operador: pedidos + entregas, sem cancelar/estornar
# - viewer: somente leitura
ADMIN_ROLE="admin"
