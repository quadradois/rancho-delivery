# ==============================================================================
# Rancho Delivery — Backend (.env)
# Copie para apps/backend/.env e preencha com suas credenciais.
# Em produção, mantenha este arquivo com permissão 600.
# ==============================================================================

# ----- Aplicação -----
NODE_ENV=development
PORT=3001
# Em produção, o backend escuta apenas em 127.0.0.1 (atrás do Nginx).
HOST=127.0.0.1
FRONTEND_URL="http://localhost:3000"
# Nº de proxies confiáveis à frente (Nginx). Usado para rate limit/IP real.
TRUST_PROXY_HOPS=2
LOG_LEVEL="info"

# ----- Banco de Dados (PostgreSQL) -----
DATABASE_URL="postgresql://user:password@localhost:5432/rancho_delivery"

# ----- IA (Claude / Anthropic) -----
# Modelo que orquestra o agente de atendimento no WhatsApp.
ANTHROPIC_API_KEY=""

# ----- WhatsApp (Evolution API) -----
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-api-key"
EVOLUTION_INSTANCE_NAME="rancho-delivery"
# Número do dono para notificações (ex: 5562999990000)
WHATSAPP_DONO=""
# Notificar o dono a cada novo pedido (true/false)
WHATSAPP_NOTIFICAR_DONO_NOVO_PEDIDO="true"

# ----- Pagamento (MercadoPago) -----
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""
MERCADOPAGO_WEBHOOK_URL="https://seu-dominio.com/webhook/mercadopago"

# ----- Pagamento (Asaas — legado / opcional) -----
# Integração legada, não utilizada no fluxo atual de pedidos.
ASAAS_API_URL=""
ASAAS_API_KEY=""
ASAAS_WEBHOOK_TOKEN=""

# ----- Autenticação do painel admin (JWT + RBAC) -----
JWT_SECRET="gere-com: openssl rand -base64 32"
# Segredo adicional de autenticação admin (gere com: openssl rand -base64 32)
ADMIN_AUTH_SECRET="gere-com: openssl rand -base64 32"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="troque-esta-senha"
# Papel do admin: admin | operador | viewer
# - admin: acesso total
# - operador: pedidos + entregas, sem cancelar/estornar
# - viewer: somente leitura
ADMIN_ROLE="admin"

# ----- Cache (Redis — opcional) -----
# Sem Redis, o cache de conversas usa memória (Map) como fallback.
REDIS_HOST=""
REDIS_PORT="6379"

# ----- Recuperação de pedidos / NPS / Jobs -----
# Recuperação de checkouts abandonados
RECOVERY_ENABLED="false"
CHECKOUT_TTL_MINUTES="30"
ABANDONO_MINUTES="60"
ABANDONO_JOB_INTERVAL_MINUTES="15"
RETRY_LINK_LIMIT="3"
# Reprocessamento de PIX e sincronização de expiração
PIX_REPROCESS_DELAY_MINUTES="5"
EXPIRACAO_SYNC_INTERVAL_MS="60000"
# Pesquisa de satisfação (NPS)
NPS_ENABLED="false"
NPS_DELAY_MINUTES="120"

# ----- Mineração de contatos (Assertiva) -----
ASSERTIVA_CLIENT_ID=""
ASSERTIVA_CLIENT_SECRET=""
ASSERTIVA_ID_FINALIDADE=1
ASSERTIVA_CACHE_TTL_DIAS=365
# 0 = sem corte por quantidade; controlar carga por concorrência.
MINERACAO_MAX_IPTUS=0
MINERACAO_ASSERTIVA_CONCURRENCY=6
