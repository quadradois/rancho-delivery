{
  "name": "rancho-delivery",
  "version": "0.8.0",
  "private": true,
  "description": "Sistema web completo para restaurante delivery-only",
  "scripts": {
    "dev": "pnpm --parallel --stream dev",
    "dev:backend": "pnpm --filter @rancho-delivery/backend dev",
    "dev:frontend": "pnpm --filter @rancho-delivery/frontend dev",
    "build": "pnpm --recursive build",
    "build:backend": "pnpm --filter @rancho-delivery/backend build",
    "build:frontend": "pnpm --filter @rancho-delivery/frontend build",
    "test": "pnpm --recursive test",
    "test:backend": "pnpm --filter @rancho-delivery/backend test",
    "test:frontend": "pnpm --filter @rancho-delivery/frontend test",
    "test:coverage": "pnpm --recursive test:coverage",
    "lint": "pnpm --recursive lint",
    "lint:fix": "pnpm --recursive lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "pnpm --recursive typecheck",
    "clean": "pnpm --recursive clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @rancho-delivery/backend db:migrate",
    "db:seed": "pnpm --filter @rancho-delivery/backend db:seed",
    "db:studio": "pnpm --filter @rancho-delivery/backend db:studio"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
